{
  "buildCommand": "cd server_fastapi && pip install -r requirements.txt",
  "installCommand": "cd server_fastapi && pip install -r requirements.txt",
  "env": {
    "MONGODB_URI": "@mongodb_uri"
  },
  "functions": {
    "api/index.py": {
      "memory": 3008,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}
